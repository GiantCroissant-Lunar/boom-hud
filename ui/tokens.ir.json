{
  "$schema": "https://boom-hud.dev/schemas/tokens.schema.json",
  "version": "1.0",
  "colors": {
    "debug-bg": {
      "value": "rgba(0, 0, 0, 0.85)",
      "description": "Debug overlay background"
    },
    "debug-text": {
      "value": "#00ff00",
      "description": "Debug text color (green terminal style)"
    },
    "debug-warning": {
      "value": "#ffaa00",
      "description": "Warning state color"
    },
    "debug-error": {
      "value": "#ff4444",
      "description": "Error state color"
    },
    "debug-muted": {
      "value": "#888888",
      "description": "Muted/secondary text color"
    },
    "hud-bg": {
      "value": "rgba(20, 20, 30, 0.9)",
      "description": "Main HUD panel background"
    },
    "hud-border": {
      "value": "#4a4a5a",
      "description": "HUD panel border color"
    },
    "hud-text": {
      "value": "#e0e0e0",
      "description": "Primary HUD text color"
    },
    "hud-accent": {
      "value": "#5588ff",
      "description": "Accent color for highlights"
    },
    "health-full": {
      "value": "#44cc44",
      "description": "Health bar at full"
    },
    "health-mid": {
      "value": "#cccc44",
      "description": "Health bar at medium"
    },
    "health-low": {
      "value": "#cc4444",
      "description": "Health bar at low"
    },
    "mana-full": {
      "value": "#4488ff",
      "description": "Mana bar color"
    }
  },
  "spacing": {
    "xs": { "value": 2, "description": "Extra small spacing" },
    "sm": { "value": 4, "description": "Small spacing" },
    "md": { "value": 8, "description": "Medium spacing" },
    "lg": { "value": 16, "description": "Large spacing" },
    "xl": { "value": 24, "description": "Extra large spacing" },
    "xxl": { "value": 32, "description": "Double extra large spacing" }
  },
  "typography": {
    "mono-xs": {
      "fontFamily": "JetBrains Mono, Consolas, monospace",
      "fontSize": 10,
      "lineHeight": 1.3,
      "description": "Extra small monospace (debug labels)"
    },
    "mono-sm": {
      "fontFamily": "JetBrains Mono, Consolas, monospace",
      "fontSize": 12,
      "lineHeight": 1.4,
      "description": "Small monospace (debug values)"
    },
    "mono-md": {
      "fontFamily": "JetBrains Mono, Consolas, monospace",
      "fontSize": 14,
      "lineHeight": 1.4,
      "description": "Medium monospace"
    },
    "ui-sm": {
      "fontFamily": "Inter, system-ui, sans-serif",
      "fontSize": 12,
      "lineHeight": 1.4,
      "description": "Small UI text"
    },
    "ui-md": {
      "fontFamily": "Inter, system-ui, sans-serif",
      "fontSize": 14,
      "lineHeight": 1.5,
      "description": "Medium UI text"
    },
    "ui-lg": {
      "fontFamily": "Inter, system-ui, sans-serif",
      "fontSize": 18,
      "fontWeight": 600,
      "lineHeight": 1.3,
      "description": "Large UI text (headings)"
    }
  },
  "radii": {
    "none": { "value": 0, "description": "No rounding" },
    "sm": { "value": 2, "description": "Subtle rounding" },
    "md": { "value": 4, "description": "Standard rounding" },
    "lg": { "value": 8, "description": "Prominent rounding" },
    "full": { "value": 9999, "description": "Fully rounded (pill shape)" }
  },
  "shadows": {
    "panel": {
      "value": {
        "type": "drop",
        "color": "rgba(0, 0, 0, 0.5)",
        "offsetX": 0,
        "offsetY": 4,
        "blur": 12,
        "spread": 0
      },
      "description": "Panel drop shadow"
    },
    "popup": {
      "value": {
        "type": "drop",
        "color": "rgba(0, 0, 0, 0.7)",
        "offsetX": 0,
        "offsetY": 8,
        "blur": 24,
        "spread": 4
      },
      "description": "Popup/modal drop shadow"
    }
  },
  "opacity": {
    "disabled": { "value": 0.5, "description": "Disabled element opacity" },
    "hover": { "value": 0.8, "description": "Hover state opacity overlay" },
    "overlay": { "value": 0.6, "description": "Background overlay opacity" }
  }
}
