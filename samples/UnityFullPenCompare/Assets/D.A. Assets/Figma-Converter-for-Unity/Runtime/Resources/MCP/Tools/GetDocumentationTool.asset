  ToolName: get_documentation
  ToolDescription: Fetches D.A. Assets documentation. Call without arguments to get
    documentation structure (list of all sections). Call with 'url' argument to get
    content of a specific page.
  Schema:
    Type: object
    Properties:
      m_Keys:
      - url
      m_Values:
      - Type: string
        Description: Optional URL of the documentation page. If omitted, returns
          the documentation structure (list of all sections). If provided, returns
          the content of that page.
