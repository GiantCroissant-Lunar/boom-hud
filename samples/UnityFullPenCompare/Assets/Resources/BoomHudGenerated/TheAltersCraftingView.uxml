                <ui:VisualElement name="ModuleFoot" class="boomhud-module-foot" />
                <ui:VisualElement name="ModulePipeLeft" class="boomhud-module-pipe-left" />
                <ui:VisualElement name="ModulePipeRight" class="boomhud-module-pipe-right" />
