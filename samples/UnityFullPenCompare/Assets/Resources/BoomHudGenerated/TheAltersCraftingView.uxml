                <ui:VisualElement name="RecipeCard02" class="boomhud-recipe-card02" />
                <ui:VisualElement name="RecipeCard03" class="boomhud-recipe-card03" />
                <ui:VisualElement name="RecipeCard04" class="boomhud-recipe-card04" />
                <ui:VisualElement name="RecipeCard05" class="boomhud-recipe-card05" />
                <ui:VisualElement name="RecipeCard06" class="boomhud-recipe-card06" />
            </ui:VisualElement>
        </ui:VisualElement>
        <ui:VisualElement name="AssemblyStage" class="boomhud-assembly-stage">
