                <ui:VisualElement name="FilterHab" class="boomhud-filter-hab" />
                <ui:VisualElement name="FilterOps" class="boomhud-filter-ops" />
            </ui:VisualElement>
            <ui:VisualElement name="RecipeCards" class="boomhud-recipe-cards">
