        <ui:VisualElement name="TopDivider" class="boomhud-top-divider" />
        <ui:VisualElement name="RecipeColumn" class="boomhud-recipe-column">
            <ui:Label name="RecipeColumnLabel" class="boomhud-recipe-column-label" />
